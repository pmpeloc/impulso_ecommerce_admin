# Prodcast E2E — Variables de entorno para tests
# Copiar este archivo a .env.test y completar los valores reales
# NUNCA commitear .env.test

# URLs de los servicios corriendo localmente
PLAYWRIGHT_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001/api/v1

# Credenciales del usuario de test
# Crear en Supabase Auth dashboard y vincular a tenant 'test-tenant'
# Ver proceso en prodcast_api/CLAUDE.md — Deuda Técnica #1
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_TENANT_ID=

# Supabase — para cleanup directo de datos de test
# Project Settings → API → service_role key
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
